/bin/zsh -lc "BIB_REVIEW_SCRIPT='
import csv, hashlib, json, re
from pathlib import Path
import xml.etree.ElementTree as ET
root = Path(\"01_search/search_logs/2026-07-20-broad-discovery/wave_03_lineage_resolution\")
batch = json.loads((root / \"identity_review_batches/identity_batch_08.json\").read_text())
with (root / \"pubmed_lineage_candidates.csv\").open(newline=\"\") as f:
    rows = list(csv.DictReader(f))
idx = {(r[\"named_source_id\"], r[\"query_id\"], r[\"candidate_key\"]): r for r in rows}
errors = []
raw_verified = 0
for item in batch:
    ns = item[\"named_source_id\"]
    target = item[\"source_to_resolve\"]
    candidates = item[\"manifested_candidates\"]
    if not candidates:
        errors.append(ns + \": no candidates\")
        continue
    for candidate in candidates:
        key = (ns, candidate[\"query_id\"], candidate[\"candidate_key\"])
        row = idx.get(key)
        if not row:
            errors.append(ns + \": candidate absent from candidate table\")
            continue
        pairs = [
            (\"candidate_key\", \"candidate_key\"),
            (\"query_id\", \"query_id\"),
            (\"candidate_rank\", \"candidate_rank\"),
            (\"title\", \"title\"),
            (\"year\", \"year\"),
            (\"authors_or_first_author\", \"authors\"),
            (\"doi\", \"doi\"),
            (\"pmid\", \"pmid\"),
            (\"primary_url\", \"source_url\"),
        ]
        for left, right in pairs:
            if str(candidate[left]) "'!= str(row[right]):
                errors.append(ns + ": input/table mismatch " + left)
        raw = root / row["raw_path"]
        if not raw.is_file():
            errors.append(ns + ": missing raw " + row["raw_path"])
            continue
        digest = hashlib.sha256(raw.read_bytes()).hexdigest()
        if digest != row["raw_sha256"]:
            errors.append(ns + ": raw SHA mismatch")
            continue
        article = ET.parse(raw).getroot().find(".//PubmedArticle")
        if article is None:
            errors.append(ns + ": no PubmedArticle")
            continue
        pmid_el = article.find(".//MedlineCitation/PMID")
        pmid = "".join(pmid_el.itertext()).strip() if pmid_el is not None else ""
        title_el = article.find(".//Article/ArticleTitle")
        title = re.sub(r"'"\\s+\", \" \", \"\".join(title_el.itertext())).strip() if title_el is not None else \"\"
        author = article.find(\".//Article/AuthorList/Author\")
        if author is None:
            first_author = \"\"
        else:
            collective = author.findtext(\"CollectiveName\") or \"\"
            fore = author.findtext(\"ForeName\") or \"\"
            last = author.findtext(\"LastName\") or \"\"
            first_author = collective or \" \".join(x for x in [fore, last] if x)
        year = article.findtext(\".//Article/Journal/JournalIssue/PubDate/Year\") or \"\"
        if not year:
            medline_date = article.findtext(\".//Article/Journal/JournalIssue/PubDate/MedlineDate\") or \"\"
            match = re.search(r\"\\b(?:19|20)\\d{2}\\b\", medline_date)
            year = match.group(0) if match else \"\"
        doi = \"\"
        for article_id in article.findall(\".//PubmedData/ArticleIdList/ArticleId\"):
            if article_id.attrib.get(\"IdType\") == \"doi\":
                doi = (article_id.text or \"\").strip().lower()
                break
        checks = [
            (\"raw PMID\", pmid, candidate[\"pmid\"]),
            (\"raw title\", title, candidate[\"title\"]),
            (\"raw first author\", first_author, target[\"first_author\"]),
            (\"raw year\", year, candidate[\"year\"]),
            (\"raw DOI\", doi, candidate[\"doi\"].lower()),
            (\"target/candidate title\", target[\"title\"], candidate[\"title\"]),
            (\"target/candidate year\", target[\"year\"], candidate[\"year\"]),
            (\"target/candidate first author\", target[\"first_author\"], candidate[\"authors_or_first_author\"].split(\";\", 1)[0]),
            (\"candidate key/PMID\", candidate[\"candidate_key\"], \"PMID:\" + candidate[\"pmid\"]),
            (\"primary URL/PMID\", candidate[\"primary_url\"], \"https://pubmed.ncbi.nlm.nih.gov/\" + candidate[\"pmid\"] + \"/\"),
        ]
        for label, actual, expected in checks:
            if actual "'!= expected:
                errors.append(ns + ": " + label + " mismatch: " + repr(actual) + " != " + repr(expected))
        raw_verified += 1
print(json.dumps({
    "named_source_count": len(batch),
    "first_named_source_id": batch[0]["named_source_id"],
    "last_named_source_id": batch[-1]["named_source_id"],
    "unique_named_source_count": len({x["named_source_id"] for x in batch}),
    "supporting_query_counts": {str(n): sum(1 for x in batch if len(x["supporting_queries"]) == n) for n in sorted({len(x["supporting_queries"]) for x in batch})},
    "candidate_counts": {str(n): sum(1 for x in batch if len(x["manifested_candidates"]) == n) for n in sorted({len(x["manifested_candidates"]) for x in batch})},
    "raw_records_verified": raw_verified,
    "error_count": len(errors),
    "errors": errors,
}, ensure_ascii=False, indent=2))
