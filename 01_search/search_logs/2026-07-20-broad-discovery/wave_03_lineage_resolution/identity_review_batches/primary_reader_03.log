/bin/zsh -lc "python3 -c '
import csv, hashlib, json, re
from pathlib import Path
from xml.etree import ElementTree as ET
root = Path(\".\")
batch_path = root / \"01_search/search_logs/2026-07-20-broad-discovery/wave_03_lineage_resolution/identity_review_batches/identity_batch_03.json\"
run_dir = batch_path.parents[1]
batch = json.loads(batch_path.read_text())
rows = list(csv.DictReader((run_dir / \"pubmed_lineage_candidates.csv\").open()))
by_pair = {(r[\"query_id\"], r[\"candidate_key\"]): r for r in rows}
def text_value(el):
    return \"\".join(el.itertext()).strip() if el is not None else \"\"
def norm(s):
    return re.sub(r\"\\\\s+\", \" \", s).strip().casefold()
for source in batch:
    checks = []
    for cand in source[\"manifested_candidates\"]:
        row = by_pair[(cand[\"query_id\"], cand[\"candidate_key\"])]
        raw = run_dir / row[\"raw_path\"]
        data = raw.read_bytes()
        sha_ok = hashlib.sha256(data).hexdigest() == row[\"raw_sha256\"]
        tree = ET.fromstring(data)
        article = next((a for a in tree.findall(\"./PubmedArticle\") if text_value(a.find(\"./MedlineCitation/PMID\")) == cand[\"pmid\"]), None)
        if article is None:
            checks.append(cand[\"candidate_key\"] + \":RAW_RECORD_MISSING\")
            continue
        title = text_value(article.find(\"./MedlineCitation/Article/ArticleTitle\"))
        first = article.find(\"./MedlineCitation/Article/AuthorList/Author\")
        if first is None:
            first_name = \"\"
        else:
            collective = text_value(first.find(\"./CollectiveName\"))
            first_name = collective or \" \".join(x for x in [text_value(first.find(\"./ForeName\")), text_value(first.find(\"./LastName\"))] if x)
        ids = {x.attrib.get(\"IdType\", \"\"): text_value(x) for x in article.findall(\"./PubmedData/ArticleIdList/ArticleId\")}
        checks.append(\"{}:sha={},title={},first={},doi={},pmid={}\".format(cand[\"candidate_key\"], sha_ok, norm(title) == norm(cand[\"title\"]), norm(first_name) == norm(cand[\"authors_or_first_author\"].split(\";\")[0]), norm(ids.get(\"doi\", \"\")) == norm(cand[\"doi\"]), ids.get(\"pubmed\", \"\") == cand[\"pmid\"]))
